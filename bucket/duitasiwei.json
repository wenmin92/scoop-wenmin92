    "description": "提供了PDF阅读、脑图制作、卡片记忆等工具，为知识的采集、整理、记忆等过程提供了辅助支撑",
    "architecture": {
        "64bit": {
            "url": "http://www.duitasiwei.com/win/%E5%A0%86%E5%A1%94%E6%80%9D%E7%BB%B4%20Setup%201.1.1.exe#/dl.7z",
            "hash": "sha512:8aeff34b1d0d1d26d6d6fbe96a3a90a3b50459d0150e2ec791b81cfce4a2959424f14af78ef8f23a7cdbb47eab8d2f5ae321f5e90fec5581c8e749a7ed0e1176",
            "installer": {
                "script": [
                    "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                    "Rename-Item \"$dir\\堆塔思维.exe\" \"$dir\\duitasiwei.exe\" -Force",
                    "Remove-Item \"$dir\\`$PLUGINSDIR\", \"$dir\\Uninstall*\" -Force -Recurse"
                ]
            }
        }
    },
    "shortcuts": [
        [
            "duitasiwei.exe",
            "DuiTaSiWei"
        ]
    ],
    "checkver": {
        "url": "http://www.duitasiwei.com/win/latest.yml",
        "regex": "Setup ([\\d.]+)\\.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "http://www.duitasiwei.com/win/%E5%A0%86%E5%A1%94%E6%80%9D%E7%BB%B4%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "http://www.duitasiwei.com/win/latest.yml",
                    "regex": "sha512: $base64"
                }
            }
        }
    }
}
