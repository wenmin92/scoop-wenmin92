            "Remove-Item \"$dir\\`$PLUGINSDIR\", \"$dir\\Uninstall*\" -Force -Recurse"
        ]
    },
    "shortcuts": [
        [
            "mubu.exe",
            "mubu"
        ]
    ],
    "checkver": {
        "url": "https://mubu.com/apps",
        "regex": "Mubu-([\\d.]+).exe"
    },
    "autoupdate": {
        "url": "http://lf6-ttcdn-tos.pstatp.com/obj/mubu-img/client/Mubu-$version.exe#/dl.7z"
    }
